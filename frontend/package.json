    "dagre": "^0.8.5",
    "framer-motion": "^12.38.0",
    "katex": "^0.16.45",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "reactflow": "^11.11.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
